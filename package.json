{
  "name": "frutiger-aero",
  "version": "2.0.0",
  "private": true,
  "description": "Frutiger Aero; a glassy, sky-themed component pack for React, Next.js and Vue.",
  "license": "MIT",
  "type": "module",
  "packageManager": "pnpm@9.15.9",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "pnpm -r --filter \"./packages/*\" build",
    "dev": "pnpm -r --parallel --filter \"./packages/*\" dev",
    "typecheck": "pnpm -r typecheck",
    "clean": "pnpm -r exec rm -rf dist .turbo node_modules/.cache"
  },
  "keywords": [
    "frutiger-aero",
    "components",
    "ui",
    "react",
    "nextjs",
    "vue",
    "glassmorphism",
    "design-system"
  ]
}
